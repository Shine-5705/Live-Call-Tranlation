# Server
PORT=3000
JWT_SECRET=change-me-in-production-use-long-random-string

# Public URL reachable by Twilio (use ngrok in dev: https://abc123.ngrok-free.app)
PUBLIC_BASE_URL=

# Twilio Programmable Voice
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=

# Spoken to PSTN party at connect time
PSTN_DISCLOSURE_MESSAGE=This call includes real-time AI translation. Your voice will be processed by automated speech services.

# Provider selection
TRANSLATION_PROVIDER=google
TTS_PROVIDER=google

# Deepgram (STT — uses 8kHz mulaw for telephony legs)
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-2

# Google AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud (Translation + TTS)
GOOGLE_API_KEY=
GOOGLE_TTS_SAMPLE_RATE=8000
GOOGLE_TTS_VOICE_PERSONA=Chirp3-HD-Aoede
GOOGLE_TRANSLATE_TIMEOUT_MS=3000
GOOGLE_TTS_TIMEOUT_MS=30000

# Optional TURN (legacy in-app VoIP mode only)
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
